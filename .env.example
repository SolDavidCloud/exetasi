# ==============================================================================
# Exetasi environment — copy to `.env` at the repo root for `docker compose`.
# The backend reads `backend/.env` if present; you can either symlink or copy
# the relevant rows. NEVER commit real secrets to this file.
# ==============================================================================

# ---- Postgres ----------------------------------------------------------------
# Compose uses these to initialise the container on first boot.
POSTGRES_USER=exetasi
POSTGRES_PASSWORD=exetasi
POSTGRES_DB=exetasi

# ---- Valkey (rate-limit backend) ---------------------------------------------
# MUST be a long, unguessable value in production. The compose file
# intentionally refuses to start without it. Generate a good one with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
VALKEY_PASSWORD=change-me-to-a-long-random-string

# ==============================================================================
# Backend settings (backend/.env)
# ==============================================================================

# ---- Auth --------------------------------------------------------------------
# Sign cookies/CSRF tokens. Required in prod. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SESSION_SECRET=replace-with-long-random-string
# Local-only dev login form — leave unset/false in any shared environment.
ENABLE_DEV_AUTH=true

# ---- Database ----------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://exetasi:exetasi@127.0.0.1:5432/exetasi

# ---- CORS / URLs -------------------------------------------------------------
FRONTEND_ORIGIN=http://127.0.0.1:9000
PUBLIC_API_BASE_URL=http://127.0.0.1:8000
CORS_ORIGINS=http://localhost:9000,http://127.0.0.1:9000

# ---- OAuth providers (blank = disabled) --------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=
GITLAB_OAUTH_BASE_URL=https://gitlab.com

# ---- Rate limiting -----------------------------------------------------------
# In production this MUST be a Valkey URL. Examples:
#   redis://:${VALKEY_PASSWORD}@127.0.0.1:6379/0
#   rediss://app_user:${VALKEY_PASSWORD}@valkey.prod:6380/0?ssl_cert_reqs=required
# Dev-only default:
RATE_LIMIT_STORAGE_URI=memory://
# RATE_LIMIT_STORAGE_URI=redis://:change-me-to-a-long-random-string@127.0.0.1:6379/0
RATE_LIMIT_STRATEGY=moving-window
# Fail closed (false) is the secure default: if Valkey is down, requests
# error rather than silently bypassing the limiter.
RATE_LIMIT_FAIL_OPEN=false
RATE_LIMIT_KEY_PREFIX=exetasi:rl

# ---- Reverse proxy -----------------------------------------------------------
# ONLY set to true if the backend is deployed behind a proxy you control
# that strips/overwrites X-Forwarded-For. Otherwise attackers can spoof
# per-IP rate-limit buckets and audit-log IPs.
TRUSTED_PROXY=false

# ---- Cookies -----------------------------------------------------------------
# Leave unset in dev; derived from FRONTEND_ORIGIN's scheme (https => secure).
# COOKIE_SECURE=true
